# ============================================================
# RunPod Environment Variables for Gemma 4 31B Uncensored
# Copy these to your RunPod Serverless Endpoint settings
# ============================================================

# === Model Configuration ===
MODEL_NAME=TrevorJS/gemma-4-31B-it-uncensored
DTYPE=bfloat16
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.92
TENSOR_PARALLEL_SIZE=1

# === Reasoning / Thinking Mode (vLLM 0.19+ required!) ===
REASONING_PARSER=gemma4

# === Performance ===
ENABLE_CHUNKED_PREFILL=true
MAX_NUM_SEQS=8

# === OpenAI API Model Name Override ===
OPENAI_SERVED_MODEL_NAME_OVERRIDE=gemma-4-31b-uncensored

# === HuggingFace Token (if model is gated) ===
# HF_TOKEN=hf_your_token_here

# === Cold Start Timeout (10 min for large model download) ===
# Set this in RunPod endpoint settings, NOT as env var
# RUNPOD_INIT_TIMEOUT=600
